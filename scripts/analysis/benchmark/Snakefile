"""Snakemake workflow for scaled Vultr-7 CBG benchmarks."""

configfile: "config/vultr7_smoke.yaml"

DATASET_IDS = config.get("dataset_ids", [f"top{k}" for k in range(1, 11)] + ["all_us"])
COMBO_IDS = config.get("combo_ids", ["S1", "S2", "L1", "L2", "B1", "B2", "B3", "B4"])
COMBO_IDS_CSV = ",".join(COMBO_IDS)
INPUT_CSV = config.get("input_csv", "datasets/cbg_test/vultr_pings_us_only.csv")
RESULTS_ROOT = config.get("results_root", "scripts/analysis/benchmark/outputs/vultr7")


rule all:
    input:
        expand(f"{RESULTS_ROOT}/{{dataset_id}}/evaluation_summary.json", dataset_id=DATASET_IDS),
        f"{RESULTS_ROOT}/scaled_benchmark_summary.json",
        f"{RESULTS_ROOT}/scaled_benchmark_summary.csv",


rule materialize_dataset:
    output:
        csv=f"{RESULTS_ROOT}/datasets/{{dataset_id}}.csv",
        manifest=f"{RESULTS_ROOT}/datasets/{{dataset_id}}.json",
    shell:
        "python -m scripts.analysis.benchmark.cli materialize-dataset "
        "{wildcards.dataset_id} "
        "--input-csv {INPUT_CSV} "
        "--output {output.csv} "
        "--manifest-output {output.manifest}"


rule run_evaluation:
    input:
        csv=f"{RESULTS_ROOT}/datasets/{{dataset_id}}.csv",
        manifest=f"{RESULTS_ROOT}/datasets/{{dataset_id}}.json",
    output:
        summary=f"{RESULTS_ROOT}/{{dataset_id}}/evaluation_summary.json",
        raw=f"{RESULTS_ROOT}/{{dataset_id}}/benchmark_phase_raw.csv",
        phase=f"{RESULTS_ROOT}/{{dataset_id}}/benchmark_phase_summary.json",
    params:
        output_dir=lambda wildcards: f"{RESULTS_ROOT}/{wildcards.dataset_id}",
    shell:
        "python -m scripts.analysis.benchmark.cli run-evaluation "
        "{wildcards.dataset_id} "
        "--input-csv {input.csv} "
        "--preselected "
        "--combo-ids {COMBO_IDS_CSV} "
        "--output-dir {params.output_dir}"


rule summarize:
    input:
        summaries=expand(f"{RESULTS_ROOT}/{{dataset_id}}/evaluation_summary.json", dataset_id=DATASET_IDS),
    output:
        json=f"{RESULTS_ROOT}/scaled_benchmark_summary.json",
        csv=f"{RESULTS_ROOT}/scaled_benchmark_summary.csv",
    shell:
        "python -m scripts.analysis.benchmark.cli summarize "
        "--results-root {RESULTS_ROOT} "
        "--output-json {output.json} "
        "--output-csv {output.csv}"

